platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  # Xcode 26 rejects the flat opus.framework shipped by opus_codec_macos 3.0.5.
  # Normalize the copied framework after CocoaPods embeds it.
  runner_project = installer.aggregate_targets.first.user_project
  runner_target = runner_project.native_targets.find { |target| target.name == 'Runner' }
  if runner_target
    phase = runner_target.shell_script_build_phases.find { |item| item.name == 'Normalize embedded Opus framework' }
    phase ||= runner_target.new_shell_script_build_phase('Normalize embedded Opus framework')
    phase.output_paths = [
      '$(TARGET_BUILD_DIR)/$(FRAMEWORKS_FOLDER_PATH)/opus.framework/Info.plist',
    ]
    phase.shell_script = <<~'SH'
      opus_framework="$TARGET_BUILD_DIR/$FRAMEWORKS_FOLDER_PATH/opus.framework"
      if [ -d "$opus_framework" ] && [ -f "$opus_framework/Info.plist" ] && [ ! -f "$opus_framework/Versions/Current/Resources/Info.plist" ]; then
        mkdir -p "$opus_framework/Versions/A/Resources"
        mv "$opus_framework/Info.plist" "$opus_framework/Versions/A/Resources/Info.plist"
        for item in opus Headers Modules; do
          if [ -e "$opus_framework/$item" ]; then
            mv "$opus_framework/$item" "$opus_framework/Versions/A/$item"
          fi
          ln -s "Versions/Current/$item" "$opus_framework/$item"
        done
        ln -s A "$opus_framework/Versions/Current"
        ln -s "Versions/Current/Resources/Info.plist" "$opus_framework/Info.plist"
      fi
    SH
    runner_project.save
  end
end
